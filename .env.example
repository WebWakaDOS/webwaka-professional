# WebWaka Professional — Environment Variables
# Copy to .env and fill in values. Never commit .env to git.

# Cloudflare D1 Database (injected by Wrangler in Workers)
# DB binding is configured in wrangler.toml

# Cloudflare R2 Storage (injected by Wrangler in Workers)
# DOCUMENTS binding is configured in wrangler.toml

# Cloudflare KV (injected by Wrangler in Workers)
# TENANT_CONFIG binding is configured in wrangler.toml

# JWT Secret (for Edge-based JWT validation)
JWT_SECRET=your-jwt-secret-here

# Nigeria-First: Paystack (primary payment gateway)
PAYSTACK_SECRET_KEY=sk_live_your_paystack_key_here
PAYSTACK_PUBLIC_KEY=pk_live_your_paystack_key_here

# Nigeria-First: Flutterwave (secondary payment gateway)
FLUTTERWAVE_SECRET_KEY=FLWSECK_your_key_here

# Nigeria-First: Termii (SMS notifications)
TERMII_API_KEY=your_termii_api_key_here
TERMII_SENDER_ID=WebWaka

# Nigeria-First: Yournotify (email notifications)
YOURNOTIFY_API_KEY=your_yournotify_api_key_here

# CORE-2 Event Bus URL (platform event bus endpoint)
EVENT_BUS_URL=https://webwaka-core-api.webwakados.workers.dev/events/publish
